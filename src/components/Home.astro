---
import { Image } from 'astro:assets';
import Socials from './Socials.astro';
import { Experience } from './Experience.jsx';
import plant1 from '../assets/plant1.svg';
---

<article class="container-fluid home">
  <div class="row w-100 h-100">
    <div class="col-sm-12 col-lg-7 avatar">
      <Experience client:load />
    </div>
    <div class="col-sm-12 col-lg-5 profile mt-sm-4">
      <div class="profile-info">
        <div><h3>Juan Sánchez Moreno</h3></div>
        <div><p>Full-stack Developer</p></div>
        <div id="hire-me-btn" class="hire-me-container">
          <a class="btn-primary" href="#contact">Hire me!</a>
          <a
            class="btn-primary"
            href="../assets/Juan_Sanchez_CV.pdf"
            download="Juan_Sanchez_CV.pdf">Download CV</a
          >
          <Image src={plant1} alt="Plant 1" class="plant d-sm-hidden" />
        </div>
        <Socials />
      </div>
    </div>
  </div>
</article>

<style scoped>
  .home {
    background: linear-gradient(to top, #312d50, var(--accent-color));
    padding: 20px;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
    height: 100vh;
    padding-top: 20px;
    padding-bottom: 20px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  @media screen and (min-width: 768px) {
    .home {
      height: calc(100vh - var(--header-height));
    }
  }
  .profile-image {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    margin-bottom: 20px;
  }
  .profile h1,
  h2,
  h3 {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 800;
    color: var(--secondary-text-color);
    text-align: center;
  }
  .profile p {
    color: var(--primary-color);
    font-size: 1.2rem;
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    text-align: center;
  }
  .home .btn-primary {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 1.2rem;
    margin-bottom: 20px;
    background-color: var(--accent-color);
    color: var(--secondary-text-color);
    text-decoration: none;
    padding: 10px 20px;
    border: 2px solid var(--secondary-text-color);
    border-radius: 8px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  .home .btn-primary:hover {
    background-color: var(--primary-color);
    color: var(--secondary-text-color);
    border-color: var(--);
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.2); /* Aumenta la sombra al hacer hover */
  }

  .profile {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
  }
  .profile div,
  a {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .profile .profile-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
    width: 65%;
  }
  .avatar {
    display: flex;
    justify-content: center;
    align-items: center;
    overflow-y: hidden;
    overflow-x: visible;
    position: relative;
  }
  @media screen and (min-width: 768px) {
    .hire-me-container {
      position: relative;
      display: inline-block;
      height: auto;
      z-index: 2;
    }

    .hire-me-container .plant {
      position: absolute;
      opacity: 0;
      transform: rotate(30deg);
      width: 50px;
      height: 50px;
      margin-left: 100px;
      margin-bottom: 50px;
      z-index: -1;
      transition: all 0.3s ease-in-out;
    }

    .hire-me-container:hover .plant {
      opacity: 1;
      transform: rotate(30deg) translateY(-10px);
      margin-left: 110px;
      margin-bottom: 60px;
    }
  }
  @media screen and (max-width: 767px) {
    .profile {
      width: 100%;
      height: 60%;
    }
    .profile-info h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-size: 1rem;
    }
    .hire-me-container .plant {
      display: none; /* Oculta la planta en dispositivos móviles */
    }
  }
</style>
